# =============================================================================
# tape-film-ichoose — example crontab fragment
# =============================================================================
# Install: /bin/bash /opt/tape-film-ichoose/scripts/install_cron.sh
#
# Times use the VM's system timezone (timedatectl).
# Managed block is replaced on each install_cron.sh run (see BEGIN/END markers).
#
# Slack (optional): set SLACK_WEBHOOK_URL in /opt/tape-film-ichoose/.env (sourced by
# run_*_with_notify.sh). If unset, notify_slack.sh logs a warning and skips posting.
# =============================================================================

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# tape-film-ichoose-cron BEGIN
# Shared lock: /opt/tape-film-ichoose/.locks/pipeline.lock
# Stock and catalog do not overlap.

# --- Stock sync (3x daily: 06:00, 14:00, 22:00 Sydney) ---
0 19 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_stock.log
0 3 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_stock.log
0 11 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_stock.log

# --- Catalog sync (daily 09:00 Sydney) ---
0 22 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_catalog_with_notify.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_catalog.log

# --- Shopify store sync (daily 09:20 Sydney) ---
20 22 * * * /bin/bash /opt/tape-film-ichoose/scripts/run_shopify_store_sync.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_shopify_store_sync.log

# --- Shopify inventory sync (daily 09:35 Sydney) ---
35 22 * * * /bin/bash /opt/tape-film-ichoose/scripts/run_shopify_inventory_sync.sh 2>&1 | /usr/bin/tee -a /opt/tape-film-ichoose/logs/cron_shopify_inventory_sync.log

# tape-film-ichoose-cron END
