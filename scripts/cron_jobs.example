# =============================================================================
# tape-film-ichoose — example crontab fragment
# =============================================================================
# Install: /bin/bash /opt/tape-film-ichoose/scripts/install_cron.sh
#
# Times use the VM's system timezone (timedatectl).
# Managed block is replaced on each install_cron.sh run (see BEGIN/END markers).
#
# Slack (optional): set SLACK_WEBHOOK_URL in /opt/tape-film-ichoose/.env (sourced by
# run_*_with_notify.sh). If unset, notify_slack.sh logs a warning and skips posting.
# =============================================================================

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# tape-film-ichoose-cron BEGIN
# Shared lock: /opt/tape-film-ichoose/.locks/pipeline.lock — stock and catalog cannot overlap.

# --- Stock sync (3x daily: 06:00, 14:00, 22:00 Sydney) ---
0 19 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh >> /opt/tape-film-ichoose/logs/cron_stock.log 2>&1
0 3 * * *  /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh >> /opt/tape-film-ichoose/logs/cron_stock.log 2>&1
0 11 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_stock_with_notify.sh >> /opt/tape-film-ichoose/logs/cron_stock.log 2>&1

# --- Catalog sync (daily 09:00 Sydney) ---
0 22 * * * /usr/bin/flock -n /opt/tape-film-ichoose/.locks/pipeline.lock /bin/bash /opt/tape-film-ichoose/scripts/run_catalog_with_notify.sh >> /opt/tape-film-ichoose/logs/cron_catalog.log 2>&1

# tape-film-ichoose-cron END
